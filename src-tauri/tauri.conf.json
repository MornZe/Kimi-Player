{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kimi-Player",
  "version": "0.1.0",
  "identifier": "com.kimi-player.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kimi Player",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Entertainment",
    "shortDescription": "Kimi Player - A modern media player",
    "longDescription": "Kimi Player is a modern cross-platform media player built with Tauri and React.",
    "copyright": "© 2024 Kimi Player"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
